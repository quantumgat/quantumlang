pub Owner {
  value: i64
}

impl Owner {
  pub setValue(next: i64) -> i64 {
    value = next
    return value
  }
}

pub badReadonlyReferenceMutation() -> i64 {
  let owner: Owner = { value: 1 }
  let reference: const &Owner = const &owner
  reference.value = 2
  return reference.value
}

pub badReadonlyPointerMutation() -> i64 {
  let owner: Owner = { value: 3 }
  let pointer: const *Owner = const *owner
  if pointer.valid {
    pointer.value = 4
    return pointer.setValue(5)
  }
  return 0
}

pub main() -> i64 {
  return badReadonlyReferenceMutation() + badReadonlyPointerMutation()
}
