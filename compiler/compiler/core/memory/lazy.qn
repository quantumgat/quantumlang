pub Lazy<T> {
  value: T
  initialized: bool = false
  generation: u64 = 0
}

impl Lazy<T> {
  pub Lazy(value: T) =
    This {
      value
      initialized: true
    }

  pub get() -> T {
    return value
  }

  pub force(value: T) -> This {
    if initialized {
      return this
    }
    return this {
      value
      initialized: true
      generation: generation + 1
    }
  }

  pub set(value: T) -> This {
    return force(value)
  }

  pub reset(value: T) -> This {
    return this {
      value
      initialized: true
      generation: generation + 1
    }
  }

  pub clear() -> This {
    return this {
      initialized: false
      generation: generation + 1
    }
  }
}

impl view Lazy<T> {
  pub ready => initialized

  pub live => initialized

  pub empty => initialized == false

  pub readable => initialized

  pub writable => initialized == false

  pub forced => initialized

  pub pending => initialized == false

  pub stable => initialized

  pub liveFor(currentGeneration: u64) -> bool {
    return live && generation == currentGeneration
  }

  pub stale(currentGeneration: u64) -> bool {
    return generation != currentGeneration
  }

  pub expired(currentGeneration: u64) -> bool {
    return stale(currentGeneration)
  }

  pub valid => initialized || initialized == false
}
