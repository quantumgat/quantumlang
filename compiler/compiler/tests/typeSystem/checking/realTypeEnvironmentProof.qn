import core::{DeclarationId, FileId, Vec}
import declaration::{DeclarationKind, DeclarationRecord, DeclarationVisibility}
import source::{SourceSpan}
import syntax::{AstRoleConformance, AstRoleVisibility}
import typeSystem::{OopSurfaceKind, OopSurfaceTable, OwnershipAddressKind, OwnershipArgumentTable, OwnershipAuthorityKind, OwnershipAuthorityTable, OwnershipUseKind, OwnershipUseRow, OwnershipUseTable, TypedNodeFact, TypeScopeTable, TypeSymbolKind, TypeSymbolTable}

pub RealTypeEnvironmentProof {
  concreteRowsOwned: bool
  declarationKindsPreserved: bool
  moduleLookupWorks: bool
  declarationLookupWorks: bool
  visibilityDerived: bool
  stableIdsAssigned: bool
  structuredScopesBuilt: bool
  lexicalLookupWorks: bool
  diagnosticsStructured: bool
  memberIdentityIsModuleOwned: bool
  genericMemberOwnersResolved: bool
  crossModuleImplOwnerResolved: bool
  repeatedImportsCoowned: bool
  enumVariantMemberResolved: bool
  enumRuntimeKindResolved: bool
  globalTypeOwnerResolved: bool
  moduleMemberCallResolved: bool
  oopSurfaceRowsBuilt: bool
  surfaceMergeKeyStable: bool
  ownershipRowsBuilt: bool
  ownershipSmartFamiliesBuilt: bool
  ownershipUseRulesEnforced: bool
  ownershipTypedNodeBridgeBuilt: bool
  ownershipArgumentAuthorityBuilt: bool
  ownershipBackendAuthorityReady: bool
  valid: bool
}

pub realTypeEnvironmentProof() -> RealTypeEnvironmentProof {
  let genericFunction = DeclarationRecord(
    3,
    DeclarationKind.Function,
    "app",
    "convert",
    FileId(1, 1, 1),
    4,
    5,
    DeclarationVisibility.Private
  )
  genericFunction.genericParameterCount = 1
  genericFunction.genericParameters = ["T"]
  genericFunction.parameters = ["input"]

  let records: Vec<DeclarationRecord> = [
    DeclarationRecord(
      1,
      DeclarationKind.Module,
      "app",
      "app",
      FileId(1, 1, 1),
      0,
      1,
      DeclarationVisibility.Public
    ),
    DeclarationRecord(
      2,
      DeclarationKind.Type,
      "app",
      "User",
      FileId(1, 1, 1),
      2,
      3,
      DeclarationVisibility.Public
    ),
    genericFunction,
    DeclarationRecord(
      4,
      DeclarationKind.Import,
      "app",
      "std",
      FileId(1, 1, 1),
      6,
      7,
      DeclarationVisibility.Private
    ),
  ]
  let table = TypeSymbolTable.fromRecords(records, true)
  let scopes = TypeScopeTable.fromSymbols(table)
  let user = table.symbolForDeclaration(DeclarationId(1, 1, 2, 2))
  let convert = table.symbolAt(2)
  let functionScope = scopes.scopeForSymbol(convert.id)
  let input = scopes.resolve(functionScope, "input")
  let generic = scopes.resolve(functionScope, "T")

  let concreteRowsOwned =
    table.symbolCount == 4 &&
    table.moduleSymbolCount == 1 &&
    table.typeSymbolCount == 1 &&
    table.functionSymbolCount == 1 &&
    table.importSymbolCount == 1

  let declarationKindsPreserved =
    table.symbolAt(0).kind == TypeSymbolKind.Module &&
    table.symbolAt(1).kind == TypeSymbolKind.Type &&
    table.symbolAt(2).kind == TypeSymbolKind.Function &&
    table.symbolAt(3).kind == TypeSymbolKind.Import

  let moduleLookupWorks =
    table.contains("app", "User") &&
    table.contains("app", "convert") &&
    table.contains("app", "missing") == false

  let declarationLookupWorks =
    user != None

  let visibilityDerived =
    table.publicSymbolCount == 2 &&
    table.privateSymbolCount == 2

  let stableIdsAssigned =
    table.symbolAt(0).stableIdentity &&
    table.symbolAt(1).stableIdentity &&
    convert.stableIdentity &&
    convert.id.id.stableKey != table.symbolAt(1).id.id.stableKey

  let structuredScopesBuilt =
    scopes.valid &&
    scopes.count >= 5 &&
    scopes.genericScopeCount == 1 &&
    scopes.bindingCount >= table.symbolCount + 2

  let lexicalLookupWorks =
    input != None &&
    generic != None

  let duplicateRecords: Vec<DeclarationRecord> = [
    records[0],
    records[1],
    records[1],
    genericFunction,
  ]
  let duplicateTable = TypeSymbolTable.fromRecords(duplicateRecords, true)
  let diagnosticsStructured =
    duplicateTable.duplicateCount == 1 &&
    duplicateTable.issueCount == 1 &&
    duplicateTable.issueAt(0).valid

  let appField = DeclarationRecord(
    5,
    DeclarationKind.Value,
    "app",
    "value",
    FileId(1, 1, 1),
    8,
    9,
    DeclarationVisibility.Public
  )
  appField.ownerTypeName = "Shared"
  appField.memberKind = "property"
  let libraryField = DeclarationRecord(
    6,
    DeclarationKind.Value,
    "library",
    "value",
    FileId(1, 2, 1),
    10,
    11,
    DeclarationVisibility.Public
  )
  libraryField.ownerTypeName = "Shared"
  libraryField.memberKind = "property"
  let moduleOwnedMembers = TypeSymbolTable.fromRecords(
    [appField, libraryField],
    true
  )
  let memberIdentityIsModuleOwned =
    moduleOwnedMembers.duplicateCount == 0 &&
    moduleOwnedMembers.symbolCount == 2 &&
    moduleOwnedMembers.symbolValueForMember(
      moduleOwnedMembers.symbolAt(0).moduleId,
      "Shared",
      "value"
    ).moduleName == "app" &&
    moduleOwnedMembers.symbolValueForMember(
      moduleOwnedMembers.symbolAt(1).moduleId,
      "Shared",
      "value"
    ).moduleName == "library"

  let rangeFrom = DeclarationRecord(
    7,
    DeclarationKind.Type,
    "ranges",
    "RangeFrom",
    FileId(1, 3, 1),
    12,
    13,
    DeclarationVisibility.Public
  )
  let rangeTo = DeclarationRecord(
    8,
    DeclarationKind.Type,
    "ranges",
    "RangeTo",
    FileId(1, 3, 1),
    14,
    15,
    DeclarationVisibility.Public
  )
  let rangeFromProperty = DeclarationRecord(
    9,
    DeclarationKind.Value,
    "ranges",
    "boundedStart",
    FileId(1, 3, 1),
    16,
    17,
    DeclarationVisibility.Public
  )
  rangeFromProperty.ownerTypeName = "RangeFrom<T>"
  rangeFromProperty.memberKind = "property"
  let rangeToProperty = DeclarationRecord(
    10,
    DeclarationKind.Value,
    "ranges",
    "boundedStart",
    FileId(1, 3, 1),
    18,
    19,
    DeclarationVisibility.Public
  )
  rangeToProperty.ownerTypeName = "RangeTo<T>"
  rangeToProperty.memberKind = "property"
  let firstCoreImport = DeclarationRecord(
    11,
    DeclarationKind.Import,
    "ranges",
    "core",
    FileId(1, 3, 1),
    20,
    21,
    DeclarationVisibility.Private
  )
  let secondCoreImport = DeclarationRecord(
    12,
    DeclarationKind.Import,
    "ranges",
    "core",
    FileId(1, 3, 1),
    22,
    23,
    DeclarationVisibility.Private
  )
  let genericOwnerTable = TypeSymbolTable.fromRecords(
    [
      rangeFrom,
      rangeTo,
      rangeFromProperty,
      rangeToProperty,
      firstCoreImport,
      secondCoreImport,
    ],
    true
  )
  let genericOwnerScopes = TypeScopeTable.fromSymbols(genericOwnerTable)
  let rangeFromScope = genericOwnerScopes.scopeForSymbol(
    genericOwnerTable.symbolAt(0).id
  )
  let rangeToScope = genericOwnerScopes.scopeForSymbol(
    genericOwnerTable.symbolAt(1).id
  )
  let genericMemberOwnersResolved =
    genericOwnerScopes.resolve(rangeFromScope, "boundedStart") != None &&
    genericOwnerScopes.resolve(rangeToScope, "boundedStart") != None
  let repeatedImportsCoowned =
    genericOwnerScopes.issueCount == 0
  let objectType = DeclarationRecord(
    13,
    DeclarationKind.Type,
    "backend.native.object.model.unitKey",
    "ObjectUnitKey",
    FileId(1, 4, 1),
    24,
    25,
    DeclarationVisibility.Public
  )
  let stableHashInto = DeclarationRecord(
    14,
    DeclarationKind.Function,
    "backend.native.object.model.stableObjectHash",
    "stableHashInto",
    FileId(1, 5, 1),
    26,
    27,
    DeclarationVisibility.Private
  )
  stableHashInto.ownerTypeName = "ObjectUnitKey"
  stableHashInto.memberKind = "method"
  stableHashInto.parameters = ["out"]
  stableHashInto.parameterRows = [
    AstCallableParameter {
      position: 0
      name: "out"
      typeName: "StableHashWriter"
      span: SourceSpan(FileId(1, 5, 1), 26, 27)
    },
  ]
  let crossModuleOwnerTable = TypeSymbolTable.fromRecords(
    [objectType, stableHashInto],
    true
  )
  let crossModuleOwnerScopes =
    TypeScopeTable.fromSymbols(crossModuleOwnerTable)
  let crossModuleImplOwnerResolved =
    crossModuleOwnerScopes.enclosingTypeOwner(
      crossModuleOwnerScopes.scopeForSymbol(
        crossModuleOwnerTable.symbolAt(1).id
      )
    ).id.same(crossModuleOwnerTable.symbolAt(0).id.id)
  let structuredParameterTypePreserved =
    crossModuleOwnerScopes.resolve(
      crossModuleOwnerScopes.scopeForSymbol(
        crossModuleOwnerTable.symbolAt(1).id
      ),
      "out"
    ) != None &&
    crossModuleOwnerScopes.resolveValue(
      crossModuleOwnerScopes.scopeForSymbol(
        crossModuleOwnerTable.symbolAt(1).id
      ),
      "out"
    ).typeName == "StableHashWriter"
  let moduleMemberCallResolved =
    crossModuleOwnerTable.symbolValueForModuleMemberCall(
      crossModuleOwnerTable.symbolAt(1).moduleId,
      "stableHashInto",
      1,
      0
    ).ownerTypeName == "ObjectUnitKey"
  let visibleName = DeclarationRecord(
    15,
    DeclarationKind.Type,
    "core.hash.hashDomain",
    "HashDomain",
    FileId(1, 6, 1),
    28,
    29,
    DeclarationVisibility.Public
  )
  let localName = DeclarationRecord(
    16,
    DeclarationKind.Type,
    "backend.native.object.model.stableObjectHash",
    "LocalObject",
    FileId(1, 5, 1),
    30,
    31,
    DeclarationVisibility.Private
  )
  let visibleNameTable = TypeSymbolTable.fromRecords(
    [visibleName, localName],
    true
  )
  let consumerModule = ModuleId(
    localName.fileId.id.packageHash,
    localName.fileId.id.moduleHash
  )
  let packageVisibleNameResolved =
    visibleNameTable.symbolValueForName(
      consumerModule,
      "HashDomain"
    ).name == "HashDomain"
  let exactModuleNameResolved =
    visibleNameTable.symbolValueForName(
      consumerModule,
      "LocalObject"
    ).name == "LocalObject"
  let conflictingVisibleName = DeclarationRecord(
    17,
    DeclarationKind.Type,
    "other.hash.hashDomain",
    "HashDomain",
    FileId(1, 7, 1),
    32,
    33,
    DeclarationVisibility.Public
  )
  let ambiguousVisibleNameTable = TypeSymbolTable.fromRecords(
    [visibleName, localName, conflictingVisibleName],
    true
  )
  let ambiguousPackageNameRejected =
    !ambiguousVisibleNameTable.symbolValueForName(
      consumerModule,
      "HashDomain"
    ).id.valid
  let globalTypeOwnerResolved =
    visibleNameTable.typeOwnerSymbolFor("HashDomain").name == "HashDomain" &&
    !ambiguousVisibleNameTable.typeOwnerSymbolFor("HashDomain").id.valid

  let hashDomainObject = DeclarationRecord(
    18,
    DeclarationKind.Function,
    "core.hash.hashDomain",
    "Object",
    FileId(1, 6, 1),
    34,
    35,
    DeclarationVisibility.Public
  )
  hashDomainObject.ownerTypeName = "HashDomain"
  hashDomainObject.memberKind = "enum-variant"
  hashDomainObject.returnTypeName = "HashDomain"
  let enumVariantTable = TypeSymbolTable.fromRecords(
    [visibleName, hashDomainObject],
    true
  )
  let enumVariantMember =
    enumVariantTable.symbolValueForMember("HashDomain", "Object")
  let enumVariantMemberResolved =
    enumVariantTable.valid &&
    enumVariantMember.id.valid &&
    enumVariantMember.kind == TypeSymbolKind.Value &&
    enumVariantMember.ownerTypeName == "HashDomain" &&
    enumVariantMember.typeName == "HashDomain" &&
    enumVariantMember.memberKind == "enum-variant"
  let runtimeEnum = DeclarationRecord(
    19,
    DeclarationKind.Unknown,
    "core.hash.hashDomain",
    "HashDomain",
    FileId(1, 6, 1),
    36,
    37,
    DeclarationVisibility.Public
  )
  runtimeEnum.returnTypeName = "enum"
  let runtimeEnumTable = TypeSymbolTable.fromRecords([runtimeEnum], true)
  let enumRuntimeKindResolved =
    runtimeEnumTable.valid &&
    runtimeEnumTable.symbolAt(0).kind == TypeSymbolKind.Enum &&
    runtimeEnumTable.typeOwnerSymbolFor(
      "HashDomain",
      runtimeEnumTable.symbolAt(0).moduleId
    ).name == "HashDomain"

  let leftImpl = DeclarationRecord(
    60,
    DeclarationKind.Impl,
    "app",
    "Counter",
    FileId(1, 9, 1),
    60,
    61,
    DeclarationVisibility.Private
  )
  leftImpl.roleConformances = [
    AstRoleConformance {
      roleName: "LeftRole"
      visibility: AstRoleVisibility.Public
      span: SourceSpan(FileId(1, 9, 1), 60, 61)
    },
  ]
  let rightImpl = DeclarationRecord(
    61,
    DeclarationKind.Impl,
    "app",
    "Counter",
    FileId(1, 9, 1),
    62,
    63,
    DeclarationVisibility.Private
  )
  rightImpl.roleConformances = [
    AstRoleConformance {
      roleName: "RightRole"
      visibility: AstRoleVisibility.Public
      span: SourceSpan(FileId(1, 9, 1), 62, 63)
    },
  ]
  let viewImpl = DeclarationRecord(
    62,
    DeclarationKind.View,
    "app",
    "Counter",
    FileId(1, 9, 1),
    64,
    65,
    DeclarationVisibility.Private
  )
  viewImpl.roleConformances = [
    AstRoleConformance {
      roleName: "ViewRole"
      visibility: AstRoleVisibility.Internal
      span: SourceSpan(FileId(1, 9, 1), 64, 65)
    },
  ]
  let surfaceTable = OopSurfaceTable.fromRecords(
    [leftImpl, rightImpl, viewImpl],
    true
  )
  let oopSurfaceRowsBuilt =
    surfaceTable.valid &&
    surfaceTable.conformanceCount == 3 &&
    surfaceTable.roleRequirementCount == 3 &&
    surfaceTable.mergedSurfaceCount == 1 &&
    surfaceTable.rows[0].kind == OopSurfaceKind.Impl &&
    surfaceTable.rows[2].kind == OopSurfaceKind.ImplView &&
    surfaceTable.rows[2].policy.viewPropertyGettersEnabled
  let surfaceMergeKeyStable =
    surfaceTable.rows[0].mergeKey == surfaceTable.rows[1].mergeKey &&
    surfaceTable.rows[0].conformanceKey != surfaceTable.rows[1].conformanceKey &&
    surfaceTable.roleRows[0].roleName == "LeftRole" &&
    surfaceTable.roleRows[1].roleName == "RightRole" &&
    surfaceTable.roleRows[2].internalVisible

  let uniqueOwner = DeclarationRecord(
    63,
    DeclarationKind.Type,
    "ownership",
    "Unique",
    FileId(1, 10, 1),
    66,
    67,
    DeclarationVisibility.Public
  )
  let weakOwner = DeclarationRecord(
    64,
    DeclarationKind.Type,
    "ownership",
    "Weak",
    FileId(1, 10, 1),
    68,
    69,
    DeclarationVisibility.Public
  )
  let sharedOwner = DeclarationRecord(
    65,
    DeclarationKind.Type,
    "ownership",
    "Shared",
    FileId(1, 10, 1),
    70,
    71,
    DeclarationVisibility.Public
  )
  let pinOwner = DeclarationRecord(
    66,
    DeclarationKind.Type,
    "ownership",
    "Pin",
    FileId(1, 10, 1),
    72,
    73,
    DeclarationVisibility.Public
  )
  let arenaOwner = DeclarationRecord(
    67,
    DeclarationKind.Type,
    "ownership",
    "Arena",
    FileId(1, 10, 1),
    74,
    75,
    DeclarationVisibility.Public
  )
  let globalOwner = DeclarationRecord(
    68,
    DeclarationKind.Type,
    "ownership",
    "Global",
    FileId(1, 10, 1),
    76,
    77,
    DeclarationVisibility.Public
  )
  let permanentOwner = DeclarationRecord(
    69,
    DeclarationKind.Type,
    "ownership",
    "Permanent",
    FileId(1, 10, 1),
    78,
    79,
    DeclarationVisibility.Public
  )
  let handleOwner = DeclarationRecord(
    70,
    DeclarationKind.Type,
    "ownership",
    "Handle",
    FileId(1, 10, 1),
    80,
    81,
    DeclarationVisibility.Public
  )
  let ownership = OwnershipAuthorityTable.fromRecords(
    [
      uniqueOwner,
      sharedOwner,
      weakOwner,
      pinOwner,
      arenaOwner,
      globalOwner,
      permanentOwner,
      handleOwner,
      genericFunction,
    ],
    true
  )
  let ownershipRowsBuilt =
    ownership.valid &&
    ownership.rowCount == 9 &&
    ownership.ownerCount == 7 &&
    ownership.callableBoundaryCount == 1 &&
    ownership.rows[0].authorityKind == OwnershipAuthorityKind.UniqueOwner &&
    ownership.rows[2].authorityKind == OwnershipAuthorityKind.WeakView
  let ownershipSmartFamiliesBuilt =
    ownership.uniqueOwnerCount == 1 &&
    ownership.sharedOwnerCount == 1 &&
    ownership.weakViewCount == 1 &&
    ownership.pinnedOwnerCount == 1 &&
    ownership.arenaRegionCount == 1 &&
    ownership.globalOwnerCount == 1 &&
    ownership.permanentOwnerCount == 1 &&
    ownership.externalHandleCount == 1 &&
    ownership.smartOwnerCount == 7 &&
    ownership.moveOnlyOwnerCount == 4 &&
    ownership.rows[0].moveOnly &&
    ownership.rows[1].sharedOwner &&
    ownership.rows[2].weakView &&
    ownership.rows[3].stableAddress &&
    ownership.rows[4].regionOwner &&
    ownership.rows[5].globalLifetime &&
    ownership.rows[6].permanentLifetime &&
    ownership.rows[7].idempotentClose
  let ownershipUses = OwnershipUseTable.fromRows(
    [
      OwnershipUseRow(
        0,
        OwnershipUseKind.CopyOwner,
        "copy unique",
        ownership.rows[0],
        OwnershipAddressKind.SmartOwner
      ),
      OwnershipUseRow(
        1,
        OwnershipUseKind.WriteThroughView,
        "write const weak view",
        ownership.rows[2],
        OwnershipAddressKind.ConstReference
      ),
      OwnershipUseRow.globalEscape(
        2,
        "escape arena pointer",
        ownership.rows[4],
        OwnershipAddressKind.Pointer
      ),
      OwnershipUseRow(
        3,
        OwnershipUseKind.ManualFree,
        "free handle",
        ownership.rows[7],
        OwnershipAddressKind.ExternalHandle
      ),
      OwnershipUseRow(
        4,
        OwnershipUseKind.CloseHandle,
        "close handle",
        ownership.rows[7],
        OwnershipAddressKind.ExternalHandle
      ),
    ],
    true
  )
  let ownershipUseRulesEnforced =
    ownershipUses.valid &&
    ownershipUses.rowCount == 5 &&
    ownershipUses.diagnosticCount == 4 &&
    ownershipUses.copyRejectCount == 1 &&
    ownershipUses.writeRejectCount == 1 &&
    ownershipUses.escapeRejectCount == 1 &&
    ownershipUses.manualReleaseRejectCount == 1 &&
    ownershipUses.diagnostics[0].code == "QTOWN0101" &&
    ownershipUses.diagnostics[1].code == "QTOWN0102" &&
    ownershipUses.diagnostics[2].code == "QTOWN0103" &&
    ownershipUses.diagnostics[3].code == "QTOWN0104"
  let ownershipTypedNodeBridge = OwnershipUseTable.fromTypedNodes(
    [
      TypedNodeFact {
        text: "free"
        typeName: "void"
        firstArgumentTypeName: "Handle"
        argumentTypeNames: ["Handle"]
        manualReleaseOperation: true
        ownershipSensitive: true
      },
      TypedNodeFact {
        text: "="
        typeName: "Unique"
        assignment: true
        copyOperation: true
      },
      TypedNodeFact {
        text: "^"
        typeName: "Unique"
        moveOperation: true
        ownershipSensitive: true
      },
      TypedNodeFact {
        text: "&"
        typeName: "Unique"
        addressOperation: true
        ownershipSensitive: true
      },
    ],
    ownership
  )
  let ownershipTypedNodeBridgeBuilt =
    ownershipTypedNodeBridge.valid &&
    ownershipTypedNodeBridge.rowCount == 4 &&
    ownershipTypedNodeBridge.diagnosticCount == 2 &&
    ownershipTypedNodeBridge.manualReleaseRejectCount == 1 &&
    ownershipTypedNodeBridge.copyRejectCount == 1 &&
    ownershipTypedNodeBridge.diagnostics[0].code == "QTOWN0104" &&
    ownershipTypedNodeBridge.diagnostics[1].code == "QTOWN0101" &&
    ownershipTypedNodeBridge.rows[2].kind == OwnershipUseKind.MoveOwner &&
    ownershipTypedNodeBridge.rows[3].kind == OwnershipUseKind.BorrowAddress
  let ownershipArgumentAuthority = OwnershipArgumentTable.forNode(
    TypedNodeFact {
      text: "unsafeBoundary"
      argumentTypeNames: ["Handle", "Unique", "string"]
    },
    ownership
  )
  let ownershipArgumentAuthorityBuilt =
    ownershipArgumentAuthority.valid &&
    ownershipArgumentAuthority.rowCount == 3 &&
    ownershipArgumentAuthority.authorityCount == 2 &&
    ownershipArgumentAuthority.rows[0].authority.externalResource &&
    ownershipArgumentAuthority.rows[1].authority.moveOnly &&
    ownershipArgumentAuthority.rows[2].hasAuthority == false
  let ownershipBackendAuthorityReady =
    ownership.backendAuthorityReady &&
    ownership.backendAuthorityCount == ownership.rowCount &&
    ownership.diagnosticCount == 0

  let valid =
    table.valid &&
    concreteRowsOwned &&
    declarationKindsPreserved &&
    moduleLookupWorks &&
    declarationLookupWorks &&
    visibilityDerived &&
    stableIdsAssigned &&
    structuredScopesBuilt &&
    lexicalLookupWorks &&
    diagnosticsStructured &&
    memberIdentityIsModuleOwned &&
    genericMemberOwnersResolved &&
    crossModuleImplOwnerResolved &&
    structuredParameterTypePreserved &&
    packageVisibleNameResolved &&
    exactModuleNameResolved &&
    ambiguousPackageNameRejected &&
    enumVariantMemberResolved &&
    enumRuntimeKindResolved &&
    globalTypeOwnerResolved &&
    moduleMemberCallResolved &&
    oopSurfaceRowsBuilt &&
    surfaceMergeKeyStable &&
    ownershipRowsBuilt &&
    ownershipSmartFamiliesBuilt &&
    ownershipUseRulesEnforced &&
    ownershipTypedNodeBridgeBuilt &&
    ownershipArgumentAuthorityBuilt &&
    ownershipBackendAuthorityReady &&
    repeatedImportsCoowned

  return RealTypeEnvironmentProof {
    concreteRowsOwned
    declarationKindsPreserved
    moduleLookupWorks
    declarationLookupWorks
    visibilityDerived
    stableIdsAssigned
    structuredScopesBuilt
    lexicalLookupWorks
    diagnosticsStructured
    memberIdentityIsModuleOwned
    genericMemberOwnersResolved
    crossModuleImplOwnerResolved
    repeatedImportsCoowned
    enumVariantMemberResolved
    enumRuntimeKindResolved
    globalTypeOwnerResolved
    moduleMemberCallResolved
    oopSurfaceRowsBuilt
    surfaceMergeKeyStable
    ownershipRowsBuilt
    ownershipSmartFamiliesBuilt
    ownershipUseRulesEnforced
    ownershipTypedNodeBridgeBuilt
    ownershipArgumentAuthorityBuilt
    ownershipBackendAuthorityReady
    valid
  }
}
