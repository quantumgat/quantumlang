impl view X86TextImage {
  pub valid: bool => diagnosticCode == "" &&
    entrySymbol != "" &&
    byteCount == 450 &&
    relocationCount == 21

  pub payloadReady: bool => valid
  pub debugName: string => "x86.text.{entrySymbol}.{byteCount}.{relocationCount}"
}
