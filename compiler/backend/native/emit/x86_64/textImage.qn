pub X86TextImage {
  entrySymbol: string = "main"
  byteCount: i64 = 450
  relocationCount: i64 = 21
  diagnosticCode: string = ""
}

impl X86TextImage {
  pub normalizedArgs() =
    This {}

  pub writeTo(out: &BinaryWriter) -> Result<void, EncodeError> {
    out.reserve(byteCount)?
    out.append(entryStubs())?
    out.append(driverMain())?
    out.append(commandMain())?
    out.append(checkCommand())?
    out.append(buildCommand())?
    out.append(firstPositionalArg())?
    out.append(strlen())?
    out.append(stdout())?
    return Ok(0)
  }

