import host::{HostFileSystem}

pub SourceFileSystem {
  root: string
  host: HostFileSystem
}

impl SourceFileSystem {
  pub SourceFileSystem(root: string) =
    This {
      root
      host: HostFileSystem(root)
    }
}

impl view SourceFileSystem {
  pub ready => root != "" && host.valid

  pub valid => ready
}
