pub NoOsPlatform {
  name: string
  syscallAbi: string
  objectFormat: string
  dynamicLinker: bool
  valid: bool
}

impl NoOsPlatform {
  pub NoOsPlatform() =
    This {
      name: "none"
      syscallAbi: "bare-metal"
      objectFormat: "elf"
      dynamicLinker: false
      valid: true
    }
}

impl view NoOsPlatform {
  pub bareMetal => dynamicLinker == false
  pub elf => objectFormat == "elf"
  pub staticOnly => valid && bareMetal
}
