pub ProcessEnv {
  symbolName: string
  available: bool
  deterministicSnapshot: bool
}

impl ProcessEnv {
  pub ProcessEnv(symbolName: string, available: bool, deterministicSnapshot: bool) =
    This {
      symbolName
      available
      deterministicSnapshot
    }

  pub host() =
    This {
      symbolName: "environ"
      available: true
      deterministicSnapshot: false
    }
}

impl view ProcessEnv {
  pub valid: bool => symbolName != ""
  pub readable: bool => valid && available
}
