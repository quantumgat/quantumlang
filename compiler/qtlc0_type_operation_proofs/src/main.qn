  let u16Result = proof_u16()
  if u16Result != 0 { return 1400 + u16Result }

  let i32Result = proof_i32()
  if i32Result != 0 { return 1500 + i32Result }

  let u32Result = proof_u32()
  if u32Result != 0 { return 1600 + u32Result }

  let i64Result = proof_i64()
