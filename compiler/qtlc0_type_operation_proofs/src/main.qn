  let byteResult = proof_byte()
  if byteResult != 0 { return 2300 + byteResult }

  let f32Result = proof_f32()
  if f32Result != 0 { return 2400 + f32Result }

  let f64Result = proof_f64()
  if f64Result != 0 { return 2500 + f64Result }

  let stringResult = proof_string()
  if stringResult != 0 { return 2600 + stringResult }

  let optionResult = proof_option()
  if optionResult != 0 { return 2700 + optionResult }

  let resultResult = proof_result()
  if resultResult != 0 { return 2800 + resultResult }

  let vecResult = proof_vec()
  if vecResult != 0 { return 2900 + vecResult }

  let arrayResult = proof_array()
  if arrayResult != 0 { return 3000 + arrayResult }

  let mapResult = proof_map()
  if mapResult != 0 { return 3100 + mapResult }

  let setResult = proof_set()
  if setResult != 0 { return 3200 + setResult }

  let rangeResult = proof_range()
  if rangeResult != 0 { return 3300 + rangeResult }

  let sliceResult = proof_slice()
  if sliceResult != 0 { return 3400 + sliceResult }

  let indexResult = proof_index()
  if indexResult != 0 { return 3500 + indexResult }

  let wideI128Result = proof_wide_i128()
